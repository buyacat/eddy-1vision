---
import models from '../content/models.json';
import accessories from '../content/accessories.json';
import { asset } from '../lib/asset.js';
---
<section class="sec models" id="models" data-screen-label="Моделі">
  <div class="wrap">
    <div class="sec-head reveal">
      <span class="eyebrow">Моделі та комплектуючі</span>
      <h2>Оберіть <span class="hl">конфігурацію</span></h2>
      <p>Три конфігурації панелі та діагоналі 65", 75", 86". Доповнюйте стійками, кріпленнями та OPS-модулем.</p>
    </div>

    <div class="model-dots" aria-hidden="true">
      {models.map(() => <span class="mdot"></span>)}
    </div>
    <div class="model-grid reveal stagger">
      {models.map((m) => (
        <div class={`model${m.flagship ? ' flagship' : ''}`}>
          <div class="vis">
            <div class="ph-stripe"></div>
            <span class="tag">65" / 75" / 86"</span>
            {m.flagship && <span class="flagtag">Flagship</span>}
            <img class="panel-img" src={asset("assets/1vision-3q.png")} alt={`Панель ${m.name}`} loading="lazy" decoding="async" />
          </div>
          <div class="body">
            <h3>{m.name}</h3>
            <div class="sub">{m.subtitle}</div>
            <div class="specs">
              {m.specs.map((s) => (
                <div class="r"><span class="k">{s.key}</span><span class="v">{s.value}</span></div>
              ))}
            </div>
            <div class="price">
              <div>
                <div class="from" data-price>{m.priceLabel}</div>
                <div class="amt" data-price-amt style={m.priceAmount ? undefined : 'display:none'} set:html={m.priceAmount ? `${m.priceAmount.replace(' ₴', '')} <span class="cur">₴</span>` : ''} />
              </div>
              <a class={`btn btn-${m.flagship ? 'primary' : 'ghost'} btn-sm`} href="#contact">Замовити</a>
            </div>
          </div>
        </div>
      ))}
    </div>
    <div class="price-note reveal">* Орієнтовна вартість комплекту з каталогу. Фінальна ціна залежить від діагоналі та комплектації — уточнюйте у менеджера.</div>

    <div class="acc-head sec-head reveal">
      <span class="eyebrow">Комплектуючі та аксесуари</span>
      <h2 style="font-size:clamp(24px,2.6vw,32px)">Доповніть під свій кабінет</h2>
    </div>
    <div class="acc-grid reveal stagger">
      <div class="acc"><div class="ic"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.9" stroke-linecap="round" stroke-linejoin="round"><rect x="6" y="3" width="12" height="9" rx="1"/><path d="M12 12v7M7 22h10M9 22a3 3 0 0 1 6 0"/></svg></div><h4>{accessories[0].title}</h4><p>{accessories[0].text}</p><div class="meta">{accessories[0].meta}</div></div>
      <div class="acc"><div class="ic"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.9" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="4" width="18" height="13" rx="2"/><path d="M12 17v4M8 21h8"/></svg></div><h4>{accessories[1].title}</h4><p>{accessories[1].text}</p><div class="meta">{accessories[1].meta}</div></div>
      <div class="acc"><div class="ic"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.9" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="6" width="20" height="12" rx="2"/><path d="M6 10h4M6 14h8"/></svg></div><h4>{accessories[2].title}</h4><p>{accessories[2].text}</p><div class="meta" set:html={accessories[2].meta} /></div>
      <div class="acc"><div class="ic"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.9" stroke-linecap="round" stroke-linejoin="round"><path d="M12 19l7-7 3 3-7 7-3-3zM18 13l-1.5-7.5L2 2l3.5 14.5L13 18M2 2l7.586 7.586"/><circle cx="11" cy="11" r="2"/></svg></div><h4>{accessories[3].title}</h4><p>{accessories[3].text}</p><div class="meta">{accessories[3].meta}</div></div>
    </div>
    <div class="acc-note reveal">Перелік комплектуючих постійно розширюється — щоб отримати актуальний, лишіть заявку або зв'яжіться з нами.</div>
  </div>
</section>
