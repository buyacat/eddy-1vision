---
import site from '../content/site.json';
import { asset } from '../lib/asset.js';
const { nav } = site;
---
<nav class="nav" id="nav" aria-label="Головна навігація">
  <div class="nav-inner">
    <a class="brand" href="#top">
      <img class="logo" src={asset("assets/eddy-black.svg")} alt="Eddy Group" />
      <span class="vline"></span>
      <img class="logo logo-1v" src={asset("assets/1vision-logo.svg")} alt="1-Vision" />
    </a>
    <div class="nav-links">
      {nav.links.map((l) => (
        <a href={l.href} target={l.external ? '_blank' : undefined} rel={l.external ? 'noreferrer' : undefined}>{l.label}</a>
      ))}
    </div>
    <div class="nav-cta">
      <a class="btn btn-primary btn-sm" href="#contact">{nav.ctaLabel}</a>
      <button class="burger" id="burger" aria-label="Меню" aria-expanded="false" aria-controls="drawer"><span></span><span></span><span></span></button>
    </div>
  </div>
</nav>

<!-- mobile drawer -->
<div class="drawer" id="drawer" role="dialog" aria-modal="true" aria-label="Меню" aria-hidden="true">
  <div class="scrim" data-close></div>
  <div class="sheet">
    {nav.links.map((l) => (
      <a href={l.href} target={l.external ? '_blank' : undefined} rel={l.external ? 'noreferrer' : undefined} data-close>{l.label}</a>
    ))}
    <a class="btn btn-primary" href="#contact" data-close>Замовити демонстрацію</a>
  </div>
</div>
